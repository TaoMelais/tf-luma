# .gitignore pour Terraform
# Fichiers de state
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variables avec données sensibles
terraform.tfvars
*.auto.tfvars

# Répertoires Terraform
.terraform/
.terraform.lock.hcl

# Fichiers de configuration IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Fichiers OS
.DS_Store
Thumbs.db
